@model EduNexus.Models.SubmitEssayViewModel

@{
    ViewData["Title"] = "Nộp Bài Tự Luận";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Nộp bài tập (Assignment ID: @Model.AssignmentId)</h4>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-controller="Assignment" asp-action="SubmitEssay" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="AssignmentId" />

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">Nội dung bài làm <span class="text-danger">*</span></label>
                            <textarea asp-for="Content" class="form-control" rows="8" placeholder="Nhập câu trả lời của bạn vào đây..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AttachedFile" class="form-label">Tài liệu đính kèm (không bắt buộc)</label>
                            <input asp-for="AttachedFile" type="file" class="form-control" />
                            <small class="text-muted">Định dạng hỗ trợ: pdf, docx, txt, zip...</small>
                            <span asp-validation-for="AttachedFile" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/" class="btn btn-secondary me-md-2">Quay lại</a>
                            <button type="submit" class="btn btn-success">Nộp bài</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
