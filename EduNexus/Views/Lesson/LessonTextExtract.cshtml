@{
    ViewData["Title"] = "Lesson Text Extract";
}

<div class="container mt-5">
    <h2>Lesson Text Extraction</h2>
    <p class="text-muted">Extract text content from lesson materials using AI.</p>
    
    <div class="card mt-4">
        <div class="card-body">
            <div class="mb-3">
                <label for="lessonFile" class="form-label">Upload Lesson File (PDF/Word)</label>
                <input class="form-control" type="file" id="lessonFile">
            </div>
            <button class="btn btn-primary" type="button">
                <i class="fa-solid fa-wand-magic-sparkles"></i> Extract Text
            </button>
        </div>
    </div>

    <div class="mt-4">
        <h4>Extracted Content</h4>
        <textarea class="form-control" rows="10" placeholder="Extracted text will appear here..."></textarea>
    </div>
</div>
